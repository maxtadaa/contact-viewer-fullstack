# ----- Server -----
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# ----- MySQL -----
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=contact_viewer

# ----- Microsoft / Outlook (Microsoft Entra ID) -----
# เอามาจาก Azure Portal > App registrations > Application (client) ID
MS_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Directory (tenant) ID ขององค์กร ใส่เพื่อจำกัดให้ล็อกอินได้เฉพาะคนในองค์กร
# ถ้าเว้นว่าง = รับทุก tenant (ไม่แนะนำสำหรับระบบภายในองค์กร)
MS_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ----- JWT -----
# สุ่มสตริงยาวๆ เก็บเป็นความลับ เช่นรันคำสั่ง: openssl rand -hex 32
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
